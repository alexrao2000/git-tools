#!/usr/bin/env bash
#
# git-here — switch to a GitHub PR's branch you already have locally.
#
# The offline counterpart to `git pr`: where `git pr` fetches a PR's branch,
# `git here` assumes you already have it and just switches — it never touches
# the network to fetch, and (once a branch has been seen) never even calls `gh`.
#
# How it resolves PR number → local branch:
#   1. Fast path (offline): branches checked out by `git pr` or a prior
#      `git here` are stamped with `git config branch.<name>.gtools-pr <n>`.
#      If a local branch carries the stamp for #n, switch to it — no network.
#   2. Fallback: no stamp (branch pulled by hand, plain `gh`, or a raw fetch)?
#      Ask `gh pr view` for the head branch name, and if that branch exists
#      locally, switch to it and stamp it so next time is offline.
#
# `git here` deliberately does NOT fetch. If you don't have the branch, it says
# so and points you at `git pr <n>`.
#
# (Named `git here`, not `git switch`: git always prefers its built-in `switch`
# over a script, so a custom `git-switch` could never run.)
#
# Usage:
#   git here 923       switch to the local branch for PR #923
#   git here -h        show this help
#
set -euo pipefail

usage() {
  cat <<'EOF'
git here — switch to a GitHub PR's branch you already have locally.

The offline counterpart to `git pr`: it assumes the branch is already local and
just switches to it. It never fetches, and for branches it has seen before it
doesn't call `gh` at all (they're stamped with the PR number on first use).

If you don't have the branch, git here won't fetch it — it points you at
`git pr <n>` instead.

Usage:
  git here 923   switch to the local branch for PR #923
  git here -h    show this help
EOF
}

case "${1:-}" in
  -h|--help|"") usage; exit 0 ;;
esac

num="$1"
echo "$num" | grep -qE '^[0-9]+$' || {
  echo "git here: expected a PR number, got '$num' (try -h)" >&2; exit 2; }

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "git here: not inside a git repository" >&2; exit 1; }

# 1) Offline fast path — a branch stamped with this PR number by git pr/git here.
stamped=$(git config --get-regexp '^branch\..*\.gtools-pr$' 2>/dev/null \
  | awk -v n="$num" '$2 == n { print $1; exit }' \
  | sed -E 's/^branch\.(.*)\.gtools-pr$/\1/') || true
if [ -n "${stamped:-}" ] && git show-ref --verify --quiet "refs/heads/$stamped"; then
  git switch "$stamped"
  exit 0
fi

# 2) Fallback — resolve the branch name via gh, then switch iff it's local.
command -v gh >/dev/null 2>&1 || {
  echo "git here: PR #$num isn't stamped on a local branch, and 'gh' isn't" >&2
  echo "  installed to look it up. Install the GitHub CLI, or use 'git pr $num'." >&2
  exit 1; }

branch=$(gh pr view "$num" --json headRefName -q .headRefName 2>/dev/null) || {
  echo "git here: couldn't find PR #$num in this repo" >&2; exit 1; }
[ -n "$branch" ] || { echo "git here: PR #$num has no head branch" >&2; exit 1; }

if git show-ref --verify --quiet "refs/heads/$branch"; then
  git config "branch.$branch.gtools-pr" "$num"  # stamp so next time is offline
  git switch "$branch"
else
  echo "git here: you don't have PR #$num ($branch) locally." >&2
  echo "  git here never fetches — pull it with:  git pr $num" >&2
  exit 1
fi
