#!/usr/bin/env bash
#
# git-prs — print the URL of every open PR you have authored in this repo.
#
# One link per line, nothing else — easy to skim or pipe. Lists open PRs
# authored by you in the current repository. Requires the GitHub CLI (`gh`).
#
# Usage:
#   git prs            print a link for each of your open PRs in this repo
#   git prs --title    append the PR title:  <link> -- <title>
#   git prs -h         show this help
#
set -euo pipefail

usage() {
  cat <<'EOF'
git prs — print the URL of every open PR you have authored in this repo.

One link per line (nothing else). Requires the GitHub CLI (gh).

Usage:
  git prs            print a link for each of your open PRs in this repo
  git prs --title    append the PR title:  <link> -- <title>  (-t)
  git prs -h         show this help
EOF
}

title=0
while [ $# -gt 0 ]; do
  case "$1" in
    -t|--title) title=1 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "git prs: unknown option '$1' (try -h)" >&2; exit 2 ;;
  esac
  shift
done

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "git prs: not inside a git repository" >&2; exit 1; }
command -v gh >/dev/null 2>&1 || {
  echo "git prs: needs the GitHub CLI ('gh') — https://cli.github.com" >&2; exit 1; }

# Repo-scoped: gh pr list reads the repo from the current directory's remote.
if [ "$title" = 1 ]; then
  gh pr list --author "@me" --state open --limit 100 --json url,title \
    --jq '.[] | "\(.url) -- \(.title)"'
else
  gh pr list --author "@me" --state open --limit 100 --json url --jq '.[].url'
fi
