#autoload
#
# PR numbers (with head-branch descriptions) + branch names, for commands
# that take either as a target. compadd must run in THIS shell, not a
# subshell, so candidates are collected into arrays first — never
# `| while read` into compadd, or the completion system never sees them.
local -a prs pr_nums pr_descs branches
prs=(${(f)"$(_gtools_open_prs)"})
local p num branch
for p in $prs; do
  num="${p%%:*}"; branch="${p#*:}"
  pr_nums+=("$num")
  pr_descs+=("$num  ($branch)")
done
branches=(${(f)"$(_gtools_branches)"})
(( $#pr_nums )) && compadd -X 'open PRs' -d pr_descs -a pr_nums
(( $#branches )) && compadd -X 'branches' -a branches
