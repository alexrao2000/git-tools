#autoload
#
# Completion for `git new` — the actual fix for chronically-verbose branch
# names: Tab cycles through short words already used in this repo's existing
# branch names (via _multi_parts, zsh's standard "compose from
# hyphen-separated segments" completer), instead of typing a sentence.
# Nothing generated or guessed — same principle as `cd` completing real
# directories, just this repo's own naming precedent instead of a filesystem.
case ${words[CURRENT-1]} in
  -b|--base) _gtools_branches; return ;;
esac
if [[ ${words[CURRENT]} == -* ]]; then
  _alternative 'flags:flag:(-b --base -h --help)'
  return
fi
local -a tokens
tokens=(${(f)"$(_gtools_branch_tokens)"})
_multi_parts - tokens
