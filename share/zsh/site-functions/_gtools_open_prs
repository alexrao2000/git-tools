#autoload
#
# Open PRs for this repo, tab-separated "NUMBER<TAB>head-branch<TAB>title" —
# best effort, silent if gh/network is unavailable.
#
# Cached per-repo for a short TTL. A fresh cache is served instantly (just a
# file read); only a stale/missing cache pays for `gh pr list` (~0.5s). To make
# even the first Tab instant, call this function in the BACKGROUND from a chpwd
# hook (`_gtools_open_prs &>/dev/null &`) so the cache is pre-warmed on entering
# a repo — then the completion just reads it and never waits on the network.
local ttl=30
local top; top="$(git rev-parse --show-toplevel 2>/dev/null)" || return
local dir="${TMPDIR:-/tmp}/gtools-comp"
[[ -d $dir ]] || mkdir -p "$dir" 2>/dev/null
local cache="$dir/prs${top//\//_}"

local now mtime
now="$(date +%s 2>/dev/null || echo 0)"
mtime="$(stat -f %m "$cache" 2>/dev/null || echo 0)"
if [[ -f $cache ]] && (( now - mtime < ttl )); then
  cat "$cache"
  return
fi

local out
out="$(gh pr list --state open --limit 200 --json number,headRefName,title \
  --jq '.[] | "\(.number)\t\(.headRefName)\t\(.title)"' 2>/dev/null)"
if [[ -n $out ]]; then
  print -r -- "$out" >| "$cache" 2>/dev/null
  print -r -- "$out"
elif [[ -f $cache ]]; then
  cat "$cache"   # gh failed (offline?) — stale is better than nothing
fi
