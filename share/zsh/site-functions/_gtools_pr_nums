#autoload
#
# Open PRs as completion candidates for `git pr` — the value inserted is the
# bare PR number; the display is "NUM -- title" with numbers right-aligned,
# others' PRs additionally suffixed "(@author)". One tag/group ('open-prs',
# one 'Open PRs' header) — coloring differentiates ownership per line instead
# of a second header: a `list-colors` zstyle (see ~/.zshrc) matches on the
# "(@" suffix to color others' PRs differently from yours. (Not escape codes
# embedded here: zsh's completion list renderer shows literal bytes for ANSI
# codes put directly in a -d string — confirmed, they don't render — whereas
# list-colors is the actual supported, properly-rendered mechanism.)
#
# Checking out another person's PR is a core use of `git pr`, so both are
# offered; naming/merging stays your call — `git pr merge --all` and the bare
# `git pr` listing are scoped to you in the command itself.
local -a prs
prs=(${(f)"$(_gtools_open_prs)"})
(( $#prs )) || return
local me; me="$(_gtools_gh_login)"

local -a nums descs
local p num rest branch author title w=0
for p in $prs; do num="${p%%$'\t'*}"; (( ${#num} > w )) && w=${#num}; done
for p in $prs; do
  num="${p%%$'\t'*}"; rest="${p#*$'\t'}"
  branch="${rest%%$'\t'*}"; rest="${rest#*$'\t'}"
  author="${rest%%$'\t'*}"; title="${rest#*$'\t'}"
  nums+=("$num")
  if [[ -z $me || $author == $me ]]; then
    descs+=("${(l:w:)num} -- ${title}")
  else
    descs+=("${(l:w:)num} -- ${title}  (@${author})")
  fi
done

local expl
_wanted open-prs expl 'Open PRs' compadd -d descs -a nums
